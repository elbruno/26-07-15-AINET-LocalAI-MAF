@page "/"
@using System.ComponentModel
@inject IChatClient ChatClient
@inject NavigationManager Nav
@inject SemanticSearch Search
@inject FoundryLocalModelStatusService ModelStatusService
@implements IDisposable

<PageTitle>Chat</PageTitle>

<ChatHeader OnNewChat="@ResetConversationAsync"
            OnPrepareModel="@PrepareModelAsync"
            OnOpenModelLocation="@OpenModelLocationAsync"
            OnDeleteModel="@DeleteDownloadedModelAsync"
            OnRefreshStatus="@RefreshStatusAsync"
            IsPreparingModel="@isPreparingModel"
            IsModelReady="@isModelReady"
            IsModelDownloaded="@isModelDownloaded"
            CanRetryPrepare="@canRetryPrepare"
            ModelAlias="@currentModelAlias"
            ModelStatus="@currentModelStatus"
            ModelStatusDetail="@currentModelStatusDetail" />

<ChatMessageList Messages="@messages" InProgressMessage="@currentResponseMessage">
    <NoMessagesContent>
        <div>To get started, try asking about these example documents. You can replace these with your own data and replace this message.</div>
        <ChatCitation File="Example_Emergency_Survival_Kit.pdf"/>
        <ChatCitation File="Example_GPS_Watch.md"/>
        <div class="quick-questions page-width">
            @foreach (var question in quickQuestions)
            {
                <button class="btn-subtle" @onclick="@(() => AskQuickQuestionAsync(question))">@question</button>
            }
        </div>
    </NoMessagesContent>
</ChatMessageList>

<div class="chat-container">
    <ChatSuggestions OnSelected="@AddUserMessageAsync" @ref="@chatSuggestions" />
    <ChatInput OnSend="@AddUserMessageAsync" @ref="@chatInput" />
    <SurveyPrompt /> @* Remove this line to eliminate the template survey message *@
</div>

@code {
    private const string SystemPrompt = @"
        You are an assistant who answers questions about information you retrieve.
        Do not answer questions about anything else.
        Use only simple markdown to format your responses.

        Use the LoadDocuments tool to prepare for searches before answering any questions.

        Use the Search tool to find relevant information. When you do this, end your
        reply with citations in the special XML format:

        <citation filename='string'>exact quote here</citation>

        Always include the citation in your response if there are results.

        The quote must be max 5 words, taken word-for-word from the search result, and is the basis for why the citation is relevant.
        Don't refer to the presence of citations; just emit these tags right at the end, with no surrounding text.
        ";

    private int statefulMessageCount;
    private readonly ChatOptions chatOptions = new();
    private readonly List<ChatMessage> messages = new();
    private readonly string[] quickQuestions =
    [
        "Tell me about the GPS watch.",
        "What are the key features of the GPS watch?",
        "Summarize the emergency survival kit."
    ];
    private CancellationTokenSource? currentResponseCancellation;
    private ChatMessage? currentResponseMessage;
    private ChatInput? chatInput;
    private ChatSuggestions? chatSuggestions;
    private string currentModelAlias = "";
    private string currentModelStatus = "";
    private string? currentModelStatusDetail;
    private bool isPreparingModel;
    private bool isModelReady;
    private bool isModelDownloaded;
    private bool canRetryPrepare;

    protected override async Task OnInitializedAsync()
    {
        statefulMessageCount = 0;
        messages.Add(new(ChatRole.System, SystemPrompt));
        chatOptions.Tools =
        [
            AIFunctionFactory.Create(
                LoadDocumentsAsync,
                "LoadDocuments",
                "Loads the documents needed for performing searches. Must be completed before a search can be executed, but only needs to be completed once."),
            AIFunctionFactory.Create(
                SearchAsync,
                "Search",
                "Searches for information using a phrase or keyword across loaded documents.")
        ];
        await RefreshModelStatusAsync();
    }

    private async Task AddUserMessageAsync(ChatMessage userMessage)
    {
        CancelAnyCurrentResponse();
        await RefreshModelStatusAsync();

        // Add the user message to the conversation
        messages.Add(userMessage);
        chatSuggestions?.Clear();
        await chatInput!.FocusAsync();

        if (!await EnsureModelReadyAsync())
        {
            chatSuggestions?.Update(messages);
            return;
        }

        // Stream and display a new response from the IChatClient
        var responseText = new TextContent("");
        currentResponseMessage = new ChatMessage(ChatRole.Assistant, [responseText]);
        currentResponseCancellation = new();
        await foreach (var update in ChatClient.GetStreamingResponseAsync(messages.Skip(statefulMessageCount), chatOptions, currentResponseCancellation.Token))
        {
            messages.AddMessages(update, filter: c => c is not TextContent);

            var textChunk = update.Text;
            if (string.IsNullOrWhiteSpace(textChunk) && update.Contents is not null)
            {
                textChunk = string.Concat(update.Contents
                    .OfType<TextContent>()
                    .Select(static content => content.Text));
            }

            if (!string.IsNullOrWhiteSpace(textChunk))
            {
                responseText.Text += textChunk;
            }

            chatOptions.ConversationId = update.ConversationId;
            ChatMessageItem.NotifyChanged(currentResponseMessage);
        }

        if (string.IsNullOrWhiteSpace(responseText.Text))
        {
            responseText.Text = "I couldn't generate a final text response. Please try again.";
        }

        // Store the final response in the conversation, and begin getting suggestions
        messages.Add(currentResponseMessage!);
        statefulMessageCount = chatOptions.ConversationId is not null ? messages.Count : 0;
        currentResponseMessage = null;
        chatSuggestions?.Update(messages);
        await RefreshModelStatusAsync();
    }

    private void CancelAnyCurrentResponse()
    {
        // If a response was cancelled while streaming, include it in the conversation so it's not lost
        if (currentResponseMessage is not null)
        {
            messages.Add(currentResponseMessage);
        }

        currentResponseCancellation?.Cancel();
        currentResponseMessage = null;
    }

    private async Task ResetConversationAsync()
    {
        CancelAnyCurrentResponse();
        messages.Clear();
        messages.Add(new(ChatRole.System, SystemPrompt));
        chatOptions.ConversationId = null;
        statefulMessageCount = 0;
        chatSuggestions?.Clear();
        await RefreshModelStatusAsync();
        await chatInput!.FocusAsync();
    }

    private async Task RefreshModelStatusAsync()
    {
        var status = await ModelStatusService.GetCurrentStatusAsync(CancellationToken.None);
        ApplyModelStatus(status);
    }

    private void ApplyModelStatus(FoundryLocalModelStatus status)
    {
        currentModelAlias = status.ModelAlias;
        currentModelStatus = status.StatusText;
        currentModelStatusDetail = status.Detail;
        isModelReady = status.IsReady;
        isModelDownloaded = status.IsDownloaded;
        canRetryPrepare = !status.IsReady;
    }

    private async Task PrepareModelAsync()
    {
        await EnsureModelReadyAsync();
    }

    private async Task AskQuickQuestionAsync(string question)
    {
        await AddUserMessageAsync(new ChatMessage(ChatRole.User, question));
    }

    private async Task RefreshStatusAsync()
    {
        await RefreshModelStatusAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenModelLocationAsync()
    {
        var result = await ModelStatusService.OpenModelLocationAsync(CancellationToken.None);
        messages.Add(new ChatMessage(ChatRole.Assistant, result.Message));
        await RefreshModelStatusAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteDownloadedModelAsync()
    {
        var result = await ModelStatusService.DeleteDownloadedModelAsync(CancellationToken.None);
        messages.Add(new ChatMessage(ChatRole.Assistant, result.Message));
        await RefreshModelStatusAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<bool> EnsureModelReadyAsync()
    {
        if (isPreparingModel)
        {
            return false;
        }

        isPreparingModel = true;
        currentModelStatus = "Preparing model (downloading if needed)...";
        currentModelStatusDetail = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var status = await ModelStatusService.EnsureModelReadyAsync(CancellationToken.None);
            ApplyModelStatus(status);

            if (status.IsReady)
            {
                return true;
            }

            messages.Add(new ChatMessage(
                ChatRole.Assistant,
                $"Model '{status.ModelAlias}' is not ready. {status.StatusText}. {status.Detail ?? "Check Foundry Local service and download the model locally."}"));
            return false;
        }
        finally
        {
            isPreparingModel = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    [Description("Loads the documents needed for performing searches. Must be completed before a search can be executed, but only needs to be completed once.")]
    private async Task LoadDocumentsAsync()
    {
        await InvokeAsync(StateHasChanged);
        await Search.LoadDocumentsAsync();
    }

    [Description("Searches for information using a phrase or keyword. Relies on documents already being loaded.")]
    private async Task<IEnumerable<string>> SearchAsync(
        [Description("The phrase to search for.")] string searchPhrase)
    {
        await InvokeAsync(StateHasChanged);
        var results = await Search.SearchAsync(searchPhrase, documentIdFilter: null, maxResults: 5);
        return results.Select(result =>
            $"<result filename=\"{result.DocumentId}\">{result.Text}</result>");
    }

    public void Dispose()
        => currentResponseCancellation?.Cancel();
}
