@page "/"
@using Analytics.Web.Services
@using Shared.Contracts
@inject AnalyticsApiClient ApiClient

<PageTitle>Usage Dashboard</PageTitle>

<h1 class="mb-3">Usage Dashboard</h1>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @ErrorMessage
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <h2 class="h6 text-muted">Total requests</h2>
                <p class="fs-4 mb-0">@DisplaySummary.TotalRequests</p>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <h2 class="h6 text-muted">Total tokens</h2>
                <p class="fs-4 mb-0">@DisplaySummary.TotalTokens</p>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <h2 class="h6 text-muted">Avg latency (ms)</h2>
                <p class="fs-4 mb-0">@DisplaySummary.AverageLatencyMs.ToString("0.0")</p>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <h2 class="h6 text-muted">Error rate</h2>
                <p class="fs-4 mb-0">@ErrorRatePercent.ToString("0.0")%</p>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h2 class="h5 mb-3">Filters</h2>
        <div class="row g-3">
            <div class="col-12 col-md-3">
                <label class="form-label" for="dateFrom">Date from</label>
                <input id="dateFrom" class="form-control" type="date" @bind="DateFrom" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label" for="dateTo">Date to</label>
                <input id="dateTo" class="form-control" type="date" @bind="DateTo" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label" for="provider">Provider</label>
                <input id="provider" class="form-control" placeholder="e.g. ollama" @bind="Provider" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label" for="model">Model</label>
                <input id="model" class="form-control" placeholder="e.g. llama3.1" @bind="Model" />
            </div>
        </div>
        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-primary" @onclick="LoadDashboardAsync" disabled="@IsLoading">Apply filters</button>
            <button class="btn btn-outline-secondary" @onclick="ResetFilters" disabled="@IsLoading">Reset</button>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h2 class="h5 mb-3">Recent requests</h2>

        @if (IsLoading)
        {
            <p class="text-muted mb-0">Loading data…</p>
        }
        else if (FilteredItems.Count == 0)
        {
            <div class="alert alert-secondary mb-0" role="status">
                No usage records match the current filters.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Time (Local)</th>
                            <th>Provider</th>
                            <th>Model</th>
                            <th>Proxy</th>
                            <th>Tokens</th>
                            <th>Latency (ms)</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in FilteredItems)
                        {
                            <tr>
                                <td>@record.RecordedAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@record.Backend</td>
                                <td>@record.Model</td>
                                <td>@record.ProxyName</td>
                                <td>@record.TotalTokens</td>
                                <td>@record.LatencyMs</td>
                                <td>
                                    @if (record.Success)
                                    {
                                        <span class="badge text-bg-success">Success</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-danger">Failed</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private const int DefaultLimit = 200;

    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }
    private DateTime? DateFrom { get; set; }
    private DateTime? DateTo { get; set; }
    private string? Provider { get; set; }
    private string? Model { get; set; }
    private IReadOnlyList<UsageRecord> FilteredItems { get; set; } = [];
    private UsageDashboardSummary DisplaySummary { get; set; } = new()
    {
        TotalRequests = 0,
        SuccessfulRequests = 0,
        FailedRequests = 0,
        TotalTokens = 0,
        AverageLatencyMs = 0
    };

    private double ErrorRatePercent => DisplaySummary.TotalRequests == 0
        ? 0
        : DisplaySummary.FailedRequests * 100d / DisplaySummary.TotalRequests;

    protected override Task OnInitializedAsync() => LoadDashboardAsync();

    private async Task LoadDashboardAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var query = new UsageRecordsQuery
            {
                Limit = DefaultLimit,
                Backend = string.IsNullOrWhiteSpace(Provider) ? null : Provider.Trim(),
                Model = string.IsNullOrWhiteSpace(Model) ? null : Model.Trim()
            };

            var summaryTask = ApiClient.GetSummaryAsync();
            var recordsTask = ApiClient.GetUsageRecordsAsync(query);

            await Task.WhenAll(summaryTask, recordsTask);

            var allItems = (await recordsTask).Items;
            FilteredItems = allItems
                .Where(ApplyDateFilter)
                .ToList();

            if (string.IsNullOrWhiteSpace(Provider) && string.IsNullOrWhiteSpace(Model) && DateFrom is null && DateTo is null)
            {
                DisplaySummary = await summaryTask;
            }
            else
            {
                var filteredTotal = FilteredItems.Count;
                var filteredSuccessful = FilteredItems.Count(x => x.Success);

                DisplaySummary = new UsageDashboardSummary
                {
                    TotalRequests = filteredTotal,
                    SuccessfulRequests = filteredSuccessful,
                    FailedRequests = filteredTotal - filteredSuccessful,
                    TotalTokens = FilteredItems.Sum(x => (long)x.TotalTokens),
                    AverageLatencyMs = filteredTotal == 0 ? 0 : FilteredItems.Average(x => (double)x.LatencyMs)
                };
            }
        }
        catch (Exception)
        {
            FilteredItems = [];
            DisplaySummary = new UsageDashboardSummary
            {
                TotalRequests = 0,
                SuccessfulRequests = 0,
                FailedRequests = 0,
                TotalTokens = 0,
                AverageLatencyMs = 0
            };
            ErrorMessage = "Could not load dashboard data right now. Please try again.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ResetFilters()
    {
        DateFrom = null;
        DateTo = null;
        Provider = null;
        Model = null;
        _ = LoadDashboardAsync();
    }

    private bool ApplyDateFilter(UsageRecord record)
    {
        var localDate = record.RecordedAtUtc.LocalDateTime.Date;
        if (DateFrom.HasValue && localDate < DateFrom.Value.Date)
        {
            return false;
        }

        if (DateTo.HasValue && localDate > DateTo.Value.Date)
        {
            return false;
        }

        return true;
    }
}
